# TTRPG OCR Console environment
# Copy to .env and replace every change_me value before running.

# Core application
NODE_ENV=production
PORT=3000
BASE_URL=http://localhost:3000

# Local Supabase/PostgreSQL database
# Use the Supabase db container name when the console joins the same Docker network.
DATABASE_URL=postgresql://postgres:change_me@supabase-db:5432/postgres?sslmode=disable
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_ANON_KEY=change_me
SUPABASE_SERVICE_KEY=change_me

# Auth and secret encryption
JWT_SECRET=change_me_generate_at_least_32_random_bytes
CREDENTIAL_ENCRYPTION_KEY=change_me_32_byte_base64_or_hex_key
SCHEDULED_TASK_COOKIE=change_me_random_session_secret

# Pipeline workspace
PIPELINE_WORKSPACE=/app/workspace
PIPELINE_CONFIG=/app/pipeline-config.yaml

# Optional Google Drive ingestion
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Example local OpenAI-compatible OCR provider
LOCAL_OCR_BASE_URL=http://host.docker.internal:8000
LOCAL_OCR_API_PREFIX=/v1
LOCAL_OCR_MODEL_ID=nemotron-3-nano-omni
