# =============================================================================
# TTRPG OCR Console — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running deploy.sh.
#
# DATABASE NOTE:
#   This console uses MySQL 8 (via Drizzle ORM + mysql2 driver).
#   The Manus-hosted version uses a managed TiDB/MySQL-compatible cloud DB.
#   For local Docker deployment, the bundled MySQL 8 service is used by default.
#   If you want to point at an external MySQL/MariaDB/TiDB/PlanetScale instance,
#   set DATABASE_URL directly and remove (or comment out) the "db:" service in
#   docker-compose.yml.
#
#   This is NOT Supabase/Postgres. The pipeline scripts (Python) connect to your
#   own Supabase/Postgres instance separately — that connection is configured in
#   the pipeline .env, not here.
# =============================================================================


# ── MySQL database (used by the console's bundled MySQL 8 container) ─────────
# These four vars are only used to configure the MySQL container itself.
# The console reads DATABASE_URL (below) at runtime.
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=ttrpg_ocr
MYSQL_USER=ocr_user
MYSQL_PASSWORD=change_me_user_password

# Full connection string consumed by the Node.js server and Drizzle ORM.
# For the bundled MySQL container, this is auto-assembled in docker-compose.yml
# from the four vars above — you do NOT need to set this manually unless you are
# pointing at an external DB.
#
# External MySQL / MariaDB / TiDB / PlanetScale example:
#   DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Leave blank to use the auto-assembled value from docker-compose.yml:
DATABASE_URL=


# ── Port the console listens on (host side) ──────────────────────────────────
HOST_PORT=3000


# ── Session & credential encryption secrets ──────────────────────────────────
# Generate both with:  openssl rand -base64 32
#
# JWT_SECRET      — signs session cookies; rotating this logs everyone out.
# CREDENTIAL_ENCRYPTION_KEY — encrypts provider API keys and DB passwords at
#                             rest. Keep this separate from JWT_SECRET so you
#                             can rotate sessions without invalidating stored
#                             credentials. Falls back to JWT_SECRET if unset
#                             (acceptable for dev, not recommended for prod).
JWT_SECRET=REPLACE_WITH_openssl_rand_-base64_32
CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_ANOTHER_openssl_rand_-base64_32


# ── Manus OAuth ───────────────────────────────────────────────────────────────
# Required for login. Copy these from your Manus project settings page.
#
# VITE_APP_ID          — the numeric Manus application ID (e.g. 12345)
# OAUTH_SERVER_URL     — Manus OAuth backend (leave as default unless self-hosting)
# VITE_OAUTH_PORTAL_URL — Manus login portal URL shown to users
# OWNER_OPEN_ID        — your Manus user open-id (grants you admin role on first login)
# OWNER_NAME           — display name for the owner account
VITE_APP_ID=
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=
OWNER_NAME=


# ── Manus built-in AI APIs (optional) ────────────────────────────────────────
# Leave blank if you are not using the Manus-hosted LLM / image generation APIs.
# These are only needed when the console is deployed on the Manus platform.
# For a fully self-hosted deployment you can leave all four blank.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=


# ── Branding (optional) ───────────────────────────────────────────────────────
VITE_APP_TITLE=TTRPG OCR Console
VITE_APP_LOGO=


# ── Analytics (optional) ──────────────────────────────────────────────────────
# Umami-compatible analytics endpoint and site ID.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
