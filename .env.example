# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string for the primary Supabase Postgres instance.
# For a locally hosted Supabase stack (port 5432 exposed on the host):
DATABASE_URL=postgresql://postgres:your-db-password@localhost:5432/postgres
# If the console container runs inside the same Docker network as Supabase:
# DATABASE_URL=postgresql://postgres:your-db-password@supabase-db:5432/postgres

# ─── Supabase REST API (optional — needed for storage, realtime, edge fns) ──
# The Kong gateway URL for your local Supabase stack (default port 8000).
SUPABASE_URL=http://localhost:8000
# Anon key from supabase-studio → Settings → API  (safe to expose to browser)
SUPABASE_ANON_KEY=
# Service role key (keep server-side only — grants full DB access)
SUPABASE_SERVICE_KEY=

# ─── Auth / Session ──────────────────────────────────────────────────────────
# Must be at least 32 random characters. Used to sign session cookies.
JWT_SECRET=change-me-use-at-least-32-random-characters

# Separate key for AES-256-GCM encryption of stored credentials.
# Defaults to JWT_SECRET when absent (not recommended for production).
CREDENTIAL_ENCRYPTION_KEY=change-me-use-at-least-32-random-characters

# ─── OAuth (optional) ────────────────────────────────────────────────────────
# Internal URL of the OAuth server (server-to-server calls).
OAUTH_SERVER_URL=
# Public URL of the OAuth portal (browser redirects). Defaults to https://manus.im.
VITE_OAUTH_PORTAL_URL=https://manus.im
# App ID registered with the OAuth provider.
VITE_APP_ID=

# ─── Analytics (optional) ────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── Built-in Forge LLM (optional) ──────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Owner bootstrap (optional) ──────────────────────────────────────────────
# Open ID of the first user who should receive owner permissions on first run.
OWNER_OPEN_ID=
